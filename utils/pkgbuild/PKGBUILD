# Maintainer: pingzi <pingzi@archlinux>
# Contributor: pingzi <pingzi@archlinux>
pkgname=pi-ext-image-gen
pkgver=0.0.2
pkgrel=1
pkgdesc='Image generation extension for Pi coding agent'
arch=('any')
url='https://github.com/pingzi/pi-image-gen'
license=('MIT')
depends=('pi-coding-agent')
optdepends=(
  'pi-coding-agent: Pi coding agent itself'
  'pi-coding-agent-git: Pi coding agent development version'
)
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/pingzi/pi-ext-image-gen/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')
install=pi-ext.install
options=('!strip' '!debug')

package() {
  install -d "${pkgdir}/usr/share/pi/extensions/pi-image-gen"
  cp -a "${srcdir}/pi-image-gen-"*"/pi-image-gen.ts" "${pkgdir}/usr/share/pi/extensions/pi-image-gen/pi-image-gen.ts"

  install -Dm644 "${srcdir}/pi-image-gen-"*"/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" 2>/dev/null || true
  install -Dm644 "${srcdir}/pi-image-gen-"*"/README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.md" 2>/dev/null || true
}
