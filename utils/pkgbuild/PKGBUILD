# Maintainer: pingzi <pingzi@archlinux>
# Contributor: pingzi <pingzi@archlinux>
pkgname=pi-ext-image-gen
pkgver=git
pkgrel=1
pkgdesc='Image generation extension for Pi coding agent — Aliyun Bailian (wan2.7, qwen-image, z-image).'
arch=('any')
url='https://github.com/YWh0301/pi-ext-image-gen'
license=('MIT')
depends=('pi-coding-agent')
makedepends=('git')
source=("git+ssh://git@github.com/YWh0301/pi-ext-image-gen.git")
sha256sums=('SKIP')
install=pi-ext.install
options=('!strip' '!debug')

package() {
  cd "${srcdir}/pi-ext-image-gen"
  install -d "${pkgdir}/usr/share/pi/extensions/pi-image-gen/extensions"
  cp -a "pi-image-gen.ts" "${pkgdir}/usr/share/pi/extensions/pi-image-gen/extensions/pi-image-gen.ts"
  install -Dm644 "package.json" "${pkgdir}/usr/share/pi/extensions/pi-image-gen/package.json"
  install -Dm644 "LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 "README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.md" 2>/dev/null || true
  install -Dm644 "AGENTS.md" "${pkgdir}/usr/share/doc/${pkgname}/AGENTS.md" 2>/dev/null || true
}
